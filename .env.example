# Copy this file to .env and fill in your key(s)
#   cp .env.example .env

# Anthropic API key (required for Claude Code)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key (optional — only if your project uses OpenAI)
# Get yours at https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Admin API key for accessing /api/waitlist/export
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# CORS allowed origins (comma-separated)
# In development this is set automatically to http://localhost:5173
# CORS_ORIGINS=https://yourdomain.com
